---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "About Ériu Sourcing | 18 Years in China | Noel, Founder";
const description = "Ériu Sourcing was built by an operator who has lived and worked in China for 18 years. We help Irish businesses source factory-direct — with a China-based team, real factory relationships, and verified QC.";

const siteUrl = 'https://eriusourcing.com';

const pageSchemas = [
  {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
      { "@type": "ListItem", "position": 2, "name": "About", "item": `${siteUrl}/about/` },
    ]
  },
  {
    "@type": "Person",
    "@id": `${siteUrl}/#founder`,
    "name": "Noel Murphy",
    "jobTitle": "CEO, Ériu Sourcing",
    "description": "18 years operating in China across sourcing, logistics, warehousing, and supply chain. Co-founded PFC Express in 2011, growing it to over €30M annual revenue. Based between Dublin and Shenzhen.",
    "url": `${siteUrl}/about/`,
    "worksFor": { "@id": `${siteUrl}/#organization` },
    "sameAs": ["https://www.linkedin.com/in/noel-murphy-ecommerce-china"],
    "knowsAbout": [
      "China Sourcing", "Factory Direct Purchasing", "Pre-shipment Quality Control",
      "Supply Chain Management", "Irish Import Logistics", "CE Compliance"
    ],
    "nationality": { "@type": "Country", "name": "Ireland" }
  }
];
---

<BaseLayout
  title={title}
  description={description}
  canonical="/about/"
  ogImage="/images/sourcing-team-meeting-shenzhen.webp"
  ogImageAlt="Noel Murphy leading a sourcing team meeting in Shenzhen with his China-based team"
  jsonLd={pageSchemas}
>

<style>
  /* ── About page layout ─────────────────────────────── */
  .about-hero {
    background: var(--color-navy);
    padding: 5rem 0 4rem;
    text-align: center;
    color: white;
  }
  .about-hero .eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-teal);
    margin-bottom: 1rem;
  }
  .about-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    color: white;
    margin-bottom: 1.25rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }
  .about-hero p {
    font-size: 1.125rem;
    color: rgba(255,255,255,0.75);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ── Founder section ───────────────────────────────── */
  .founder-section {
    padding: 5rem 0;
    background: var(--color-bg);
  }
  .founder-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .founder-img-wrap {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(15,33,49,0.15);
  }
  .founder-img-wrap img {
    width: 100%;
    height: auto;
    display: block;
  }
  .founder-badge {
    position: absolute;
    bottom: 1.25rem;
    left: 1.25rem;
    background: var(--color-emerald);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.4rem 0.9rem;
    border-radius: 6px;
    letter-spacing: 0.04em;
  }
  .founder-content .eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-teal);
    margin-bottom: 1rem;
  }
  .founder-content h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--color-navy);
    margin-bottom: 1.25rem;
  }
  .founder-content p {
    color: #4b5563;
    line-height: 1.75;
    margin-bottom: 1.1rem;
  }
  .founder-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #e5e7eb;
  }
  .stat-item {
    text-align: center;
  }
  .stat-number {
    font-size: 1.875rem;
    font-weight: 800;
    color: var(--color-emerald);
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .stat-label {
    font-size: 0.8rem;
    color: #6b7280;
    font-weight: 500;
    line-height: 1.3;
  }

  /* ── Infrastructure section ────────────────────────── */
  .infra-section {
    padding: 5rem 0;
    background: white;
  }
  .infra-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }
  .infra-header .eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-teal);
    margin-bottom: 0.75rem;
  }
  .infra-header h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--color-navy);
    margin-bottom: 0.75rem;
  }
  .infra-header p {
    color: #4b5563;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .infra-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }
  .infra-img {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(15,33,49,0.1);
  }
  .infra-img img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    display: block;
  }
  .infra-img figcaption {
    padding: 0.75rem 1rem;
    font-size: 0.8rem;
    color: #6b7280;
    font-style: italic;
    background: #f9fafb;
    border-top: 1px solid #f3f4f6;
  }
  .infra-context {
    background: var(--color-navy);
    border-radius: 12px;
    padding: 2rem 2.5rem;
    color: white;
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }
  .infra-context-icon {
    font-size: 2rem;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }
  .infra-context h3 {
    color: white;
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
  }
  .infra-context p {
    color: rgba(255,255,255,0.75);
    font-size: 0.925rem;
    line-height: 1.65;
    margin: 0;
  }
  .infra-context strong {
    color: var(--color-teal);
  }

  /* ── Team section ──────────────────────────────────── */
  .team-section {
    padding: 5rem 0;
    background: var(--color-bg);
  }
  .team-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .team-header .eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-teal);
    margin-bottom: 0.75rem;
  }
  .team-header h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--color-navy);
  }
  .team-img-full {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 12px 48px rgba(15,33,49,0.12);
    margin-bottom: 2rem;
  }
  .team-img-full img {
    width: 100%;
    height: auto;
    display: block;
  }
  .team-caption {
    text-align: center;
    font-size: 0.875rem;
    color: #6b7280;
    font-style: italic;
  }

  /* ── Client history section ────────────────────────── */
  .clients-section {
    padding: 5rem 0;
    background: white;
  }
  .clients-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .clients-header .eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-teal);
    margin-bottom: 0.75rem;
  }
  .clients-header h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--color-navy);
    margin-bottom: 0.75rem;
  }
  .clients-header p {
    color: #4b5563;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .client-photos {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  .client-photo {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(15,33,49,0.08);
  }
  .client-photo img {
    width: 100%;
    height: 240px;
    object-fit: cover;
    display: block;
  }
  .client-photo figcaption {
    padding: 0.625rem 0.875rem;
    font-size: 0.78rem;
    color: #6b7280;
    font-style: italic;
    background: #f9fafb;
  }
  .logos-strip {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
    padding: 2.5rem 0;
    border-top: 1px solid #e5e7eb;
    border-bottom: 1px solid #e5e7eb;
  }
  .logos-strip img {
    height: 36px;
    width: auto;
    object-fit: contain;
    opacity: 0.55;
    filter: grayscale(1);
    transition: opacity 0.2s, filter 0.2s;
  }
  .logos-strip img:hover {
    opacity: 0.85;
    filter: grayscale(0);
  }
  .logos-label {
    text-align: center;
    margin-top: 1.25rem;
    font-size: 0.8rem;
    color: #9ca3af;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ── CTA ───────────────────────────────────────────── */
  .about-cta {
    padding: 5rem 0;
    background: var(--color-emerald);
    text-align: center;
    color: white;
  }
  .about-cta h2 {
    color: white;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin-bottom: 1rem;
  }
  .about-cta p {
    color: rgba(255,255,255,0.8);
    max-width: 500px;
    margin: 0 auto 2rem;
    line-height: 1.65;
  }
  .about-cta .btn--white {
    display: inline-block;
    background: white;
    color: var(--color-emerald);
    font-weight: 700;
    padding: 0.875rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.95rem;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .about-cta .btn--white:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }

  @media (max-width: 768px) {
    .founder-grid { grid-template-columns: 1fr; gap: 2rem; }
    .infra-grid { grid-template-columns: 1fr; }
    .client-photos { grid-template-columns: 1fr 1fr; }
    .founder-stats { grid-template-columns: repeat(3, 1fr); }
    .logos-strip { gap: 1.5rem; }
    .infra-context { flex-direction: column; gap: 1rem; padding: 1.5rem; }
  }
  @media (max-width: 480px) {
    .client-photos { grid-template-columns: 1fr; }
  }
</style>

<!-- HERO -->
<section class="about-hero">
  <div class="container">
    <span class="eyebrow">About Ériu Sourcing</span>
    <h1>Built by someone who has actually lived and worked in China</h1>
    <p>18 years. Multiple businesses. Factories in 14 provinces. Over €100M in goods moved. This is what the operation behind Ériu Sourcing looks like.</p>
  </div>
</section>

<!-- FOUNDER -->
<section class="founder-section">
  <div class="container">
    <div class="founder-grid">
      <div class="founder-img-wrap">
        <img
          src="/images/sourcing-team-meeting-shenzhen.webp"
          alt="Noel leading a sourcing team meeting in Shenzhen with his China-based team"
          width="700" height="525"
          loading="lazy"
        />
        <span class="founder-badge">Shenzhen, China</span>
      </div>
      <div class="founder-content">
        <span class="eyebrow">The Founder</span>
        <h2>18 years on the ground. Not on a flight watching YouTube about China.</h2>
        <p>Ériu Sourcing was started because Irish businesses were paying too much and getting too little. The problem was not the factories. It was the distance — and the layers of intermediaries that distance created.</p>
        <p>I moved to China in 2008. I spent years learning how manufacturing works at factory level — not from a trading desk in Dublin, but from production floors in Guangdong, Henan, Zhejiang, and Fujian. I learned Mandarin well enough to negotiate directly with factory owners, not their export sales reps.</p>
        <p>In 2011, I co-founded PFC Express in Shenzhen — a China-based fulfilment and logistics operation that grew to over €30M in annual revenue. That business gave us infrastructure, verified factory relationships, and a 53-person team on the ground — 47 in Shenzhen, 6 in Zhengzhou — that Irish sourcing clients can now access directly through Ériu Sourcing.</p>
        <p>We are not a middleman. We are the presence in China that removes the need for one.</p>
        <div class="founder-stats">
          <div class="stat-item">
            <div class="stat-number">18</div>
            <div class="stat-label">Years in China</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">€30M+</div>
            <div class="stat-label">Logistics revenue built</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">14</div>
            <div class="stat-label">Provinces sourced</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- INFRASTRUCTURE -->
<section class="infra-section">
  <div class="container">
    <div class="infra-header">
      <span class="eyebrow">Our China Infrastructure</span>
      <h2>A real operation — not a laptop and a Alibaba account</h2>
      <p>Ériu Sourcing is backed by physical infrastructure built over 18 years: offices in Shenzhen and Zhengzhou, a China-based team, and established factory relationships across every major manufacturing region.</p>
    </div>
    <div class="infra-grid">
      <figure class="infra-img">
        <img
          src="/images/noel-warehouse-china.webp"
          alt="Noel in our China pick-and-pack warehouse showing operational scale"
          width="700" height="300"
          loading="lazy"
        />
        <figcaption>Our China warehouse — pick, pack, and quality check before dispatch</figcaption>
      </figure>
      <figure class="infra-img">
        <img
          src="/images/noel-dongguan-factory-visit.webp"
          alt="Noel with factory owners on a production floor inspection in Dongguan"
          width="700" height="300"
          loading="lazy"
        />
        <figcaption>On-site factory inspection in Dongguan — production floor, not a showroom</figcaption>
      </figure>
    </div>
    <div class="infra-context">
      <div class="infra-context-icon">🏭</div>
      <div>
        <h3>What "our own infrastructure" actually means for you</h3>
        <p>Ériu Sourcing operates out of <strong>Royal Logistics Group (PFC)</strong> — a logistics and fulfilment business we built in Shenzhen since 2011. It means we have offices in Shenzhen and Zhengzhou, a 53-person China team, and warehouse space we own and operate. When we say we can inspect your goods before they ship, that is not a subcontracted claim. We are physically there. Our staff are permanent employees, not freelance agents hired per job. That is the difference between a sourcing operation that can actually protect your order and one that cannot.</p>
      </div>
    </div>
  </div>
</section>

<!-- TEAM -->
<section class="team-section">
  <div class="container">
    <div class="team-header">
      <span class="eyebrow">The Team</span>
      <h2>An Irishman who lives in China. With a 53-person team behind him.</h2>
    </div>
    <div class="team-img-full">
      <img
        src="/images/pfc-office-team-china.webp"
        alt="The PFC Express team in Shenzhen — 53 China-based staff supporting Ériu Sourcing operations"
        width="1200" height="600"
        loading="lazy"
      />
    </div>
    <p class="team-caption">Our Shenzhen-based team — the operational backbone behind every Ériu Sourcing order</p>
  </div>
</section>

<!-- CLIENT HISTORY -->
<section class="clients-section">
  <div class="container">
    <div class="clients-header">
      <span class="eyebrow">Track Record</span>
      <h2>Clients from 4 continents. Including some you know.</h2>
      <p>Over 18 years we have sourced for brands from Ireland, the US, Europe, and beyond — from early-stage startups to businesses at €50M–€100M+ scale.</p>
    </div>
    <div class="client-photos">
      <figure class="client-photo">
        <img
          src="/images/clients-sunnycoco-china-visit.webp"
          alt="Client visit from Sunnycoco Clothing USA — sourcing trip to China with our team"
          width="500" height="240"
          loading="lazy"
        />
        <figcaption>Client visit — Sunnycoco Clothing, USA</figcaption>
      </figure>
      <figure class="client-photo">
        <img
          src="/images/clients-eastern-europe-meeting.webp"
          alt="Eastern European clients at our Royal Logistics facility in Shenzhen"
          width="500" height="240"
          loading="lazy"
        />
        <figcaption>Client briefing — Eastern Europe buyers at our Shenzhen office</figcaption>
      </figure>
      <figure class="client-photo">
        <img
          src="/images/client-meeting-europe.webp"
          alt="Noel meeting with European clients and our China-based sourcing team"
          width="500" height="240"
          loading="lazy"
        />
        <figcaption>Client meeting — European buyers with our team</figcaption>
      </figure>
    </div>
    <div class="logos-strip">
      <img src="/images/logo-triangl.webp" alt="TRIANGL Swimwear" width="120" height="36" loading="lazy" />
      <img src="/images/logo-sparkpaws.webp" alt="Spark Paws" width="140" height="36" loading="lazy" />
      <img src="/images/logo-paddywagon.webp" alt="Paddywagon Tours" width="130" height="36" loading="lazy" />
      <img src="/images/logo-titan-sports.webp" alt="Titan Sports Limerick" width="110" height="36" loading="lazy" />
    </div>
    <p class="logos-label">A selection of brands we have worked with. Current clients are not named — confidentiality is part of the service.</p>
  </div>
</section>

<!-- CTA -->
<section class="about-cta">
  <div class="container">
    <h2>If you're importing from China, talk to us first.</h2>
    <p>A 20-minute call is enough to tell you whether factory-direct is achievable for your product and volume — and what it would save you.</p>
    <a href="/contact" class="btn--white">Get a sourcing quote</a>
  </div>
</section>

</BaseLayout>
