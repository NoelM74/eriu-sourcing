---
// index.astro — Ériu Sourcing Homepage
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "China Sourcing Agent Ireland | Factory-Direct from Zhengzhou & Shenzhen | Ériu Sourcing";
const description = "Buy direct from Chinese factories. No Alibaba middlemen. Pre-shipment QC inspection. CE compliance verified. 18 years China experience. Save 35–60% vs Irish wholesale.";

const stats = [
  { figure: '18', label: 'Years in China' },
  { figure: '€30M+', label: 'Logistics company revenue' },
  { figure: '35–60%', label: 'Typical savings vs wholesale' },
  { figure: '2', label: 'China bases: Zhengzhou + Shenzhen' },
];

const benefits = [
  {
    headline: 'Factory gate pricing',
    body: 'You pay what the factory charges, not what three layers of middlemen add on top. Direct relationships built over 18 years mean the price is real.',
  },
  {
    headline: 'QC before it leaves China',
    body: "Every order is inspected at the factory before it ships. If it fails, it stays. You don't pay freight on goods that aren't right.",
  },
  {
    headline: 'CE marking and EU compliance',
    body: 'We verify certifications at source, not after customs. Construction materials, electronics, apparel — all checked against current EU and Irish standards.',
  },
  {
    headline: 'No Alibaba middlemen',
    body: 'Most "factories" on Alibaba are trading companies adding 20–40% margin. We source directly from the manufacturer, in person, with relationships that go back years.',
  },
];

const categories = [
  { name: 'Fashion & Apparel', href: '/product-categories#fashion', icon: '👕' },
  { name: 'Electronics', href: '/product-categories#electronics', icon: '📱' },
  { name: 'Furniture & Fit-Out', href: '/product-categories#furniture', icon: '🪑' },
  { name: 'Construction Materials', href: '/product-categories#construction', icon: '🏗️' },
  { name: 'Hospitality', href: '/product-categories#hospitality', icon: '🏨' },
  { name: 'Pet Supplies', href: '/product-categories#pet', icon: '🐾' },
  { name: 'Bags & Luggage', href: '/product-categories#bags', icon: '👜' },
  { name: 'Modular Buildings', href: '/product-categories#modular-buildings', icon: '🏭' },
];
---

<BaseLayout title={title} description={description} canonical="/">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner container">
      <div class="hero-content">
        <p class="hero-eyebrow">China Direct Sourcing — Ireland &amp; UK</p>
        <h1>Factory-direct from Zhengzhou and Shenzhen.<br />QC before it ships.</h1>
        <p class="hero-sub">No Alibaba middlemen. No trading company markups. No compliance surprises. One person with 18 years of factory-level relationships across China — buying direct for Irish businesses.</p>
        <div class="hero-actions">
          <a href="/contact" class="btn btn--primary">Get Factory Pricing →</a>
          <a href="/how-it-works" class="btn btn--secondary">See How It Works</a>
        </div>
      </div>
    </div>
    <div class="hero-image-wrap">
      <img
        src="/images/hero-china-factory-floor.webp"
        alt="Chinese electronics manufacturing factory floor — Ériu Sourcing sources directly from facilities like this"
        width="1200"
        height="675"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar section--alt">
    <div class="container">
      <ul class="stats-row" role="list">
        {stats.map(stat => (
          <li class="stat-item">
            <span class="stat-figure">{stat.figure}</span>
            <span class="stat-label">{stat.label}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="benefits-section section">
    <div class="container">
      <div class="section-header">
        <h2>Why buy direct from China?</h2>
        <p>Every Irish business buying Chinese goods through a wholesaler or trading company is paying for layers of margin they don't need to.</p>
      </div>
      <div class="benefits-grid">
        {benefits.map((b, i) => (
          <div class="benefit-card">
            <span class="benefit-num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{b.headline}</h3>
            <p>{b.body}</p>
          </div>
        ))}
      </div>
      <div class="benefits-cta">
        <a href="/why-direct" class="btn btn--secondary">The full cost argument →</a>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS TEASER -->
  <section class="process-section section section--alt">
    <div class="container">
      <div class="section-header">
        <h2>How it works</h2>
        <p>Four steps from your brief to your goods at the Irish port.</p>
      </div>
      <ol class="process-steps" role="list">
        <li>
          <span class="step-num">1</span>
          <div class="step-content">
            <h3>You brief me</h3>
            <p>Product, quantity, spec, timeline. Ten minutes via email or WhatsApp is enough to start.</p>
          </div>
        </li>
        <li>
          <span class="step-num">2</span>
          <div class="step-content">
            <h3>I find the right factory</h3>
            <p>I go to the factory — Zhengzhou, Shenzhen, Foshan, wherever — negotiate the price, and send you a sourcing report with supplier options.</p>
          </div>
        </li>
        <li>
          <span class="step-num">3</span>
          <div class="step-content">
            <h3>QC before it ships</h3>
            <p>I inspect your order before it leaves China. CE compliance verified. Failures stay at the factory — not in a container heading your way.</p>
          </div>
        </li>
        <li>
          <span class="step-num">4</span>
          <div class="step-content">
            <h3>Shipped to Ireland</h3>
            <p>I manage the freight, documentation, and customs coordination. You get landed goods at factory-gate value — not three layers of markup.</p>
          </div>
        </li>
      </ol>
      <div class="process-cta">
        <a href="/how-it-works" class="btn btn--primary">Full process breakdown →</a>
      </div>
    </div>
  </section>

  <!-- QC SECTION -->
  <section class="qc-section section">
    <div class="container">
      <div class="qc-grid">
        <div class="qc-content">
          <h2>Inspected before it ships. Every time.</h2>
          <p>Most sourcing problems happen because no one checks the goods at the factory. By the time the container arrives in Dublin, it's too late and too expensive to fix.</p>
          <p>Every order through Ériu Sourcing is physically inspected before it leaves China. Product counts, quality checks, CE certification verification — done in person, at the factory, before a container is sealed.</p>
          <p>If it fails, we resolve it with the factory before it ships. Not after.</p>
          <a href="/contact" class="btn btn--primary">Get QC-protected sourcing →</a>
        </div>
        <div class="qc-image">
          <img
            src="/images/qc-inspection-hands.webp"
            alt="Pre-shipment quality control inspection at Chinese factory — Ériu Sourcing"
            width="600"
            height="450"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCT CATEGORIES -->
  <section class="categories-section section section--alt">
    <div class="container">
      <div class="section-header">
        <h2>What we source</h2>
        <p>Ireland's top import categories from China — all covered with factory-level relationships.</p>
      </div>
      <ul class="categories-list" role="list">
        {categories.map(cat => (
          <li>
            <a href={cat.href} class="category-card">
              <span class="category-icon" aria-hidden="true">{cat.icon}</span>
              <span class="category-name">{cat.name}</span>
              <span class="category-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
      <div class="categories-cta">
        <a href="/product-categories" class="btn btn--secondary">See all categories →</a>
      </div>
    </div>
  </section>

  <!-- NETWORK TEASER -->
  <section class="network-section section">
    <div class="container">
      <div class="network-grid">
        <div class="network-image">
          <img
            src="/images/zhengzhou-hsr-station.webp"
            alt="Zhengzhou East Railway Station — HSR hub connecting Ériu Sourcing's factory network across China"
            width="700"
            height="394"
            loading="lazy"
          />
        </div>
        <div class="network-content">
          <h2>Two bases. Reach across China.</h2>
          <p>Zhengzhou puts me in the centre of Eastern China's manufacturing heartland. Every major industrial city — Beijing, Shanghai, Xi'an, Wuhan — is within 2–3 hours by high-speed rail.</p>
          <p>Shenzhen gives direct access to Guangdong's consumer goods cluster: electronics in Huaqiangbei, furniture in Foshan, pet accessories in Guangzhou, bags in Dongguan.</p>
          <p>No other Ireland-facing sourcing service has this dual-province setup.</p>
          <a href="/china-network" class="btn btn--secondary">See the full network →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-cta section section--dark">
    <div class="container--narrow">
      <h2>Ready to pay factory prices?</h2>
      <p>Send me what you're looking for. I'll come back with real factory pricing, a supplier shortlist, and a timeline — no obligation, no hard sell.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn--white">Get a Quote →</a>
        <a href="https://wa.me/353871187806" class="btn btn--secondary" target="_blank" rel="noopener noreferrer">WhatsApp Noel</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO */
  .hero { padding: 4rem 0 0; background-color: var(--color-bg); overflow: hidden; }
  .hero-inner { padding-bottom: 3rem; }
  .hero-content { max-width: 680px; }
  .hero-eyebrow { font-size: 0.875rem; font-weight: 700; color: var(--color-teal); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1rem; }
  .hero h1 { font-size: clamp(2rem, 4.5vw, 3.25rem); line-height: 1.1; margin-bottom: 1.25rem; color: var(--color-navy); }
  .hero-sub { font-size: clamp(1rem, 1.5vw, 1.125rem); color: var(--color-slate); line-height: 1.7; margin-bottom: 2rem; max-width: 58ch; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .hero-image-wrap { width: 100%; aspect-ratio: 16 / 6; overflow: hidden; }
  .hero-image-wrap img { width: 100%; height: 100%; object-fit: cover; object-position: center 40%; }

  /* TRUST BAR */
  .trust-bar { padding: 2.5rem 0; border-top: 1px solid rgba(15,33,49,.08); border-bottom: 1px solid rgba(15,33,49,.08); }
  .stats-row { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(4,1fr); gap: 2rem; text-align: center; }
  .stat-item { display: flex; flex-direction: column; gap: .25rem; }
  .stat-figure { font-family: var(--font-display); font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 700; color: var(--color-emerald); line-height: 1; }
  .stat-label { font-size: .875rem; color: var(--color-grey); line-height: 1.4; }

  /* SECTION HEADER */
  .section-header { max-width: 640px; margin-bottom: 3rem; }
  .section-header h2 { margin-bottom: .75rem; }
  .section-header p { font-size: var(--text-lg); color: var(--color-slate); line-height: 1.65; margin: 0; }

  /* BENEFITS */
  .benefits-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 2rem; margin-bottom: 2.5rem; }
  .benefit-card { padding: 2rem; background: var(--color-white); border: 1px solid rgba(15,33,49,.08); border-radius: var(--radius-lg); }
  .benefit-num { display: block; font-family: var(--font-display); font-size: .875rem; font-weight: 700; color: var(--color-teal); letter-spacing: .05em; margin-bottom: .75rem; }
  .benefit-card h3 { font-size: 1.25rem; margin-bottom: .625rem; }
  .benefit-card p { font-size: .9375rem; color: var(--color-slate); line-height: 1.65; margin: 0; max-width: none; }

  /* PROCESS */
  .process-steps { list-style: none; margin: 0 0 2.5rem; padding: 0; display: grid; grid-template-columns: repeat(2,1fr); gap: 2rem; }
  .process-steps li { display: flex; gap: 1.25rem; align-items: flex-start; }
  .step-num { flex-shrink: 0; font-family: var(--font-display); font-size: 2rem; font-weight: 700; color: var(--color-emerald); line-height: 1; min-width: 2.5rem; }
  .step-content h3 { font-size: 1.125rem; margin-bottom: .5rem; }
  .step-content p { font-size: .9375rem; color: var(--color-slate); line-height: 1.65; margin: 0; max-width: none; }

  /* QC */
  .qc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .qc-content p { color: var(--color-slate); margin-bottom: 1rem; }
  .qc-image img { width: 100%; height: 400px; object-fit: cover; border-radius: var(--radius-lg); }

  /* CATEGORIES */
  .categories-list { list-style: none; margin: 0 0 2rem; padding: 0; display: grid; grid-template-columns: repeat(4,1fr); gap: 1rem; }
  .category-card { display: flex; align-items: center; gap: .875rem; padding: 1.25rem; background: var(--color-white); border: 1px solid rgba(15,33,49,.08); border-radius: var(--radius-md); text-decoration: none; color: var(--color-navy); font-weight: 500; font-size: .9375rem; transition: border-color .12s ease, box-shadow .12s ease; min-height: 56px; }
  .category-card:hover { border-color: var(--color-teal); box-shadow: 0 2px 12px rgba(28,124,131,.1); color: var(--color-emerald); }
  .category-icon { font-size: 1.375rem; flex-shrink: 0; }
  .category-name { flex: 1; line-height: 1.3; }
  .category-arrow { color: var(--color-grey); transition: color .12s ease; }
  .category-card:hover .category-arrow { color: var(--color-teal); }

  /* NETWORK */
  .network-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 4rem; align-items: center; }
  .network-image img { width: 100%; border-radius: var(--radius-lg); }
  .network-content p { color: var(--color-slate); margin-bottom: 1rem; }

  /* FINAL CTA */
  .final-cta { text-align: center; padding: 5rem 0; }
  .final-cta h2 { font-size: clamp(1.75rem, 3.5vw, 2.75rem); margin-bottom: 1rem; }
  .final-cta p { font-size: var(--text-lg); color: rgba(255,255,255,.75); margin: 0 auto 2.5rem; max-width: 56ch; text-align: center; }
  .cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .stats-row { grid-template-columns: repeat(2,1fr); }
    .benefits-grid { grid-template-columns: 1fr; }
    .process-steps { grid-template-columns: 1fr; }
    .qc-grid { grid-template-columns: 1fr; }
    .qc-image { order: -1; }
    .qc-image img { height: 280px; }
    .categories-list { grid-template-columns: repeat(2,1fr); }
    .network-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 540px) {
    .hero-image-wrap { aspect-ratio: 4/3; }
    .categories-list { grid-template-columns: 1fr; }
    .cta-actions { flex-direction: column; align-items: center; }
  }
</style>
