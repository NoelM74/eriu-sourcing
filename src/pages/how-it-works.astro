---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "How Factory-Direct Sourcing from China Works | Ériu Sourcing Ireland";
const description = "Four steps from your product brief to landed goods in Ireland. Factory identification, price negotiation, pre-shipment QC inspection, and shipping coordination — all handled.";

const steps = [
  {
    num: '01',
    title: 'You send me a brief',
    body: [
      'Tell me the product, rough quantity, any spec or reference you have, and your timeline. WhatsApp or email is fine. Ten minutes of your time is enough to get started.',
      'No long forms. No onboarding process. Just a direct conversation about what you need.',
    ],
    detail: 'What helps: product name or reference, target quantity, any samples or images you already have, budget range, timeline.',
  },
  {
    num: '02',
    title: 'I identify and vet the right factory',
    body: [
      'Based on your brief, I identify manufacturers — not trading companies — with the right capability. I visit the facility, verify their production capacity, check their export history, and negotiate price at factory level.',
      'The sourcing report you receive includes a shortlist of vetted suppliers, FOB pricing, sample costs, MOQs, and lead times.',
    ],
    detail: 'I have active factory relationships across Zhengzhou, Shenzhen, Foshan, Guangzhou, Dongguan, and Zhongshan — covering every major Irish import category.',
  },
  {
    num: '03',
    title: 'Pre-shipment QC and CE compliance check',
    body: [
      'Once production is complete, I inspect your order at the factory before a container is sealed. This is a physical inspection — not a paperwork review.',
      'For regulated products (electronics, construction materials, apparel for children), we verify CE marking documentation and EU compliance standards at the point of origin. Problems fixed here are cheap. Problems fixed after the goods land in Dublin are expensive.',
    ],
    detail: 'Inspection covers: product count, visual quality check, labelling and packaging requirements, certification verification, and carton/pallet spec.',
  },
  {
    num: '04',
    title: 'Freight coordination and Irish delivery',
    body: [
      'I coordinate the freight booking, export documentation, and shipping logistics. For full container loads (FCL) or consolidated shipments (LCL), I work with established freight partners to get your goods to Ireland efficiently.',
      'You get advance notification of shipment, tracking references, and a clear landed cost breakdown — so there are no surprises at the port.',
    ],
    detail: 'Transit times: ~25–35 days sea freight from Shenzhen/Guangzhou to Dublin. Air freight available for urgent, lower-volume shipments.',
  },
];

const tiers = [
  {
    name: 'Sourcing Retainer',
    price: '€500–€2,000/month',
    target: 'Mid-size retailers, hotel procurement, contractors with recurring sourcing needs.',
    includes: ['Ongoing supplier identification', 'Price negotiation', 'QC inspection', 'Shipping coordination', 'Best for businesses importing €100K–€5M annually'],
  },
  {
    name: 'Project-Based Sourcing',
    price: '3–8% of order value or fixed fee',
    target: 'eCommerce brands, boutique retailers, hospitality fit-outs, one-off sourcing projects.',
    includes: ['Product category sourcing', 'Supplier shortlist + factory audit', 'Sample management', 'Pre-shipment inspection', 'Best for single sourcing projects'],
  },
  {
    name: 'QC & Compliance Only',
    price: 'Per-inspection fee',
    target: 'Businesses already sourcing from China but experiencing quality issues.',
    includes: ['Pre-shipment inspection', 'CE/EN compliance verification', 'Product testing coordination', 'Low barrier entry point', 'No full sourcing mandate required'],
  },
];
---

<BaseLayout title={title} description={description} canonical="/how-it-works">

  <section class="page-hero section">
    <div class="container--narrow">
      <p class="eyebrow">How It Works</p>
      <h1>From your brief to your goods in Ireland.</h1>
      <p class="lead">Four clear steps. No surprises. Everything managed from the factory floor to your Irish door.</p>
    </div>
  </section>

  <section class="steps-section section section--alt">
    <div class="container">
      <ol class="steps-list">
        {steps.map(step => (
          <li class="step-block">
            <div class="step-num">{step.num}</div>
            <div class="step-body">
              <h2>{step.title}</h2>
              {step.body.map(para => <p>{para}</p>)}
              <div class="step-detail">
                <strong>Details: </strong>{step.detail}
              </div>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="tiers-section section">
    <div class="container">
      <div class="section-header">
        <h2>Service options</h2>
        <p>Three ways to work together — from a single sourcing project to an ongoing monthly retainer.</p>
      </div>
      <div class="tiers-grid">
        {tiers.map(tier => (
          <div class="tier-card">
            <div class="tier-header">
              <h3>{tier.name}</h3>
              <span class="tier-price">{tier.price}</span>
            </div>
            <p class="tier-target">{tier.target}</p>
            <ul class="tier-includes">
              {tier.includes.map(item => (
                <li>{item}</li>
              ))}
            </ul>
            <a href="/contact" class="btn btn--primary">Enquire →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-strip section section--dark">
    <div class="container--narrow" style="text-align:center">
      <h2>Ready to start?</h2>
      <p>Send me a brief. No commitment required to get a sourcing report.</p>
      <a href="/contact" class="btn btn--white">Get a Quote →</a>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero { padding-top: 5rem; padding-bottom: 3rem; }
  .eyebrow { font-size: .875rem; font-weight: 700; color: var(--color-teal); text-transform: uppercase; letter-spacing: .08em; margin-bottom: .75rem; }
  .lead { font-size: 1.125rem; color: var(--color-slate); line-height: 1.7; margin: 1rem 0 0; max-width: 54ch; }

  .steps-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 3rem; }
  .step-block { display: grid; grid-template-columns: 80px 1fr; gap: 2rem; align-items: flex-start; }
  .step-num { font-family: var(--font-display); font-size: 3rem; font-weight: 700; color: var(--color-emerald); line-height: 1; padding-top: .25rem; }
  .step-body h2 { font-size: 1.5rem; margin-bottom: 1rem; }
  .step-body p { color: var(--color-slate); margin-bottom: .875rem; }
  .step-detail { font-size: .9rem; color: var(--color-grey); background: var(--color-white); border-left: 3px solid var(--color-teal); padding: .875rem 1.25rem; border-radius: 0 var(--radius-sm) var(--radius-sm) 0; margin-top: 1rem; }

  .section-header { max-width: 600px; margin-bottom: 2.5rem; }
  .tiers-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
  .tier-card { background: var(--color-white); border: 1px solid rgba(15,33,49,.1); border-radius: var(--radius-lg); padding: 2rem; display: flex; flex-direction: column; gap: 1rem; }
  .tier-header { display: flex; flex-direction: column; gap: .375rem; }
  .tier-header h3 { font-size: 1.125rem; margin: 0; }
  .tier-price { font-size: .875rem; font-weight: 700; color: var(--color-teal); }
  .tier-target { font-size: .9rem; color: var(--color-slate); margin: 0; line-height: 1.55; }
  .tier-includes { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .5rem; flex: 1; }
  .tier-includes li { font-size: .875rem; color: var(--color-slate); padding-left: 1.25rem; position: relative; line-height: 1.45; }
  .tier-includes li::before { content: '✓'; position: absolute; left: 0; color: var(--color-emerald); font-weight: 700; }
  .tier-includes li:last-child { color: var(--color-grey); font-style: italic; }
  .tier-includes li:last-child::before { content: ''; }

  .cta-strip { padding: 4rem 0; }
  .cta-strip p { color: rgba(255,255,255,.75); font-size: 1.125rem; margin: .75rem auto 2rem; max-width: 48ch; }

  @media (max-width: 900px) {
    .tiers-grid { grid-template-columns: 1fr; }
    .step-block { grid-template-columns: 56px 1fr; gap: 1.25rem; }
    .step-num { font-size: 2rem; }
  }
</style>
