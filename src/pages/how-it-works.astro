---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "How Factory-Direct China Sourcing Works | Ériu Sourcing Ireland";
const description = "Four steps from brief to delivery: factory identification, price negotiation, pre-shipment QC, and freight to Ireland — all handled from China.";

const steps = [
  {
    num: '01',
    title: 'You send me a brief',
    body: [
      'Tell me the product, rough quantity, any spec or reference you have, and your timeline. WhatsApp or email is fine. Ten minutes of your time is enough to get started.',
      'No long forms. No onboarding process. Just a direct conversation about what you need.',
    ],
    detail: 'What helps: product name or reference, target quantity, any samples or images you have, budget range, and timeline.',
  },
  {
    num: '02',
    title: 'I identify and vet the right factory',
    body: [
      'Based on your brief, I identify manufacturers — not trading companies — with the right capability. I visit the facility, verify their production capacity, check their export history, and negotiate price at factory level.',
      'The sourcing report you receive includes a shortlist of vetted suppliers, FOB pricing, sample costs, MOQs, and lead times.',
    ],
    detail: 'Active factory relationships across Zhengzhou, Shenzhen, Foshan, Guangzhou, Dongguan, and Zhongshan — covering every major Irish import category.',
  },
  {
    num: '03',
    title: 'Pre-shipment QC and CE compliance check',
    body: [
      'Once production is complete, I inspect your order at the factory before a container is sealed. This is a physical inspection — not a paperwork review.',
      'For regulated products (electronics, construction materials, children\'s apparel), we verify CE marking documentation and EU compliance standards at the point of origin. Problems fixed in China are cheap. Problems fixed after the goods land in Dublin are expensive.',
    ],
    detail: 'Inspection covers: product count, visual quality, labelling and packaging requirements, certification verification, and carton/pallet spec.',
  },
  {
    num: '04',
    title: 'Freight coordination and Irish delivery',
    body: [
      'I coordinate the freight booking, export documentation, and shipping logistics. For full container loads (FCL) or consolidated shipments (LCL), I work with established freight partners to get your goods to Ireland efficiently.',
      'You get advance shipment notification, tracking references, and a clear landed cost breakdown — no surprises at the port.',
    ],
    detail: 'Transit times: ~25–35 days sea freight from Shenzhen/Guangzhou to Dublin. Air freight available for urgent, lower-volume shipments.',
  },
];

const tiers = [
  {
    name: 'Sourcing Retainer',
    price: '€500–€2,000/month',
    target: 'Mid-size retailers, hotel procurement, contractors with recurring sourcing needs.',
    includes: ['Ongoing supplier identification', 'Price negotiation', 'QC inspection included', 'Shipping coordination', 'Best for businesses importing €100K–€5M annually'],
  },
  {
    name: 'Project-Based Sourcing',
    price: '3–8% of order value',
    target: 'eCommerce brands, boutique retailers, hospitality fit-outs, one-off projects.',
    includes: ['Product category sourcing', 'Supplier shortlist + factory audit', 'Sample management', 'Pre-shipment inspection', 'Best for single sourcing projects'],
  },
  {
    name: 'QC & Compliance Only',
    price: 'Per-inspection fee',
    target: 'Businesses already sourcing from China but experiencing quality issues.',
    includes: ['Pre-shipment inspection', 'CE/EN compliance verification', 'Product testing coordination', 'Low-barrier entry point', 'No full sourcing mandate required'],
  },
];
---

<BaseLayout title={title} description={description} canonical="/how-it-works">

  <!-- PAGE HERO -->
  <section class="page-hero section--lg">
    <div class="container--narrow">
      <span class="section-eyebrow">How It Works</span>
      <h1>From your brief to your goods in Ireland.</h1>
      <p class="lead">Four clear steps. No surprises. Everything managed from the factory floor to your Irish door.</p>
    </div>
  </section>

  <!-- STEPS -->
  <section class="section section--alt">
    <div class="container">
      <ol class="steps-list">
        {steps.map(step => (
          <li class="step-block">
            <div class="step-num">{step.num}</div>
            <div class="step-body">
              <h2>{step.title}</h2>
              {step.body.map(para => <p>{para}</p>)}
              <div class="step-detail">
                <strong>Detail: </strong>{step.detail}
              </div>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- SERVICE TIERS -->
  <section class="section">
    <div class="container">
      <div class="tiers-header">
        <span class="section-eyebrow">Service options</span>
        <h2>Three ways to work together</h2>
        <p class="tiers-lead">From a single sourcing project to a monthly retainer — structured around what your business actually needs.</p>
      </div>
      <div class="tiers-list">
        {tiers.map((tier, i) => (
          <div class="tier-row">
            <div class="tier-left">
              <h3>{tier.name}</h3>
              <span class="tier-price">{tier.price}</span>
              <p class="tier-target">{tier.target}</p>
            </div>
            <ul class="tier-includes">
              {tier.includes.map(item => (
                <li>{item}</li>
              ))}
            </ul>
            <div class="tier-action">
              <a href="/contact" class="btn btn--secondary">Enquire →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="section--emerald cta-strip">
    <div class="container--narrow" style="text-align:center">
      <span class="section-eyebrow section-eyebrow--light">No commitment needed</span>
      <h2>Ready to start?</h2>
      <p>Send me a brief. I'll come back with real factory pricing, a supplier shortlist, and a timeline — no obligation.</p>
      <a href="/contact" class="btn btn--white">Get a Quote →</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* PAGE HERO */
  .page-hero {
    border-bottom: 1px solid rgba(15, 33, 49, 0.08);
  }

  .page-hero h1 {
    font-size: clamp(2.25rem, 5vw, 4rem);
    margin-bottom: 1.25rem;
  }

  .lead {
    font-size: 1.25rem;
    color: #5a5a5a;
    line-height: 1.7;
    margin: 0;
    max-width: 52ch;
  }

  /* STEPS */
  .steps-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .step-block {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 2.5rem;
    align-items: flex-start;
    padding: 3rem 0;
    border-bottom: 1px solid rgba(15, 33, 49, 0.1);
  }

  .step-block:last-child {
    border-bottom: none;
  }

  .step-num {
    font-family: var(--font-display, Georgia, serif);
    font-size: 3.5rem;
    font-weight: 700;
    color: #1A533E;
    line-height: 1;
    opacity: 0.35;
  }

  .step-body h2 {
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .step-body p {
    color: #3a3a3a;
    margin-bottom: 1rem;
    max-width: 68ch;
  }

  .step-detail {
    font-size: 0.9375rem;
    color: #5a5a5a;
    background: #ffffff;
    border-left: 3px solid #1C7C83;
    padding: 1rem 1.375rem;
    border-radius: 0 8px 8px 0;
    margin-top: 0.5rem;
    line-height: 1.6;
    max-width: 68ch;
  }

  /* SERVICE TIERS */
  .tiers-header {
    max-width: 640px;
    margin-bottom: 3rem;
  }

  .tiers-header h2 {
    margin-bottom: 0.75rem;
  }

  .tiers-lead {
    font-size: 1.125rem;
    color: #5a5a5a;
    margin: 0;
  }

  .tiers-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid rgba(15, 33, 49, 0.1);
  }

  .tier-row {
    display: grid;
    grid-template-columns: 280px 1fr auto;
    gap: 3rem;
    align-items: start;
    padding: 2.5rem 0;
    border-bottom: 1px solid rgba(15, 33, 49, 0.1);
  }

  .tier-left h3 {
    font-size: 1.25rem;
    margin-bottom: 0.375rem;
  }

  .tier-price {
    display: block;
    font-size: 0.9375rem;
    font-weight: 700;
    color: #1C7C83;
    margin-bottom: 0.875rem;
  }

  .tier-target {
    font-size: 0.9375rem;
    color: #6b6b6b;
    margin: 0;
    line-height: 1.55;
  }

  .tier-includes {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tier-includes li {
    font-size: 0.9375rem;
    color: #3a3a3a;
    padding-left: 1.5rem;
    position: relative;
    line-height: 1.5;
  }

  .tier-includes li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #1A533E;
    font-weight: 700;
  }

  .tier-includes li:last-child {
    color: #6b6b6b;
    font-style: italic;
  }

  .tier-includes li:last-child::before {
    content: '';
  }

  .tier-action {
    padding-top: 0.25rem;
  }

  /* CTA STRIP */
  .cta-strip {
    padding: 5rem 0;
  }

  .cta-strip h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 1rem;
  }

  .cta-strip p {
    font-size: 1.125rem;
    margin: 0 auto 2rem;
    max-width: 50ch;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .tier-row {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .step-block {
      grid-template-columns: 64px 1fr;
      gap: 1.5rem;
    }

    .step-num {
      font-size: 2.5rem;
    }
  }
</style>
