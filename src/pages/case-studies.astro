---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "China Sourcing Results for Irish Businesses | Ériu Sourcing";
const description = "Real results: fashion brand to 8-figure revenue, hotel fit-out at 45% saving, electronics retailer saved 52% on landed cost. Factory-direct from China.";

const caseStudies = [
  {
    id: 'fashion-brand',
    label: 'Fashion & Apparel',
    title: 'Apparel brand scaled from €2M to 8-figure revenue',
    summary: 'A performance apparel brand needed to cut unit costs to fund growth. We moved sourcing from UK-based importing agents to factory-direct from Guangzhou and Foshan, restructured the supplier base, and built in pre-shipment QC as standard.',
    results: [
      'Cut landed cost per unit by 43% vs previous supply chain',
      'Supplier base consolidated from 7 to 3 primary factories',
      'QC rejection rate dropped from 8% to under 1%',
      'Brand grew to 8-figure annual revenue over 4 years',
    ],
    note: 'Client identity withheld at their request.',
  },
  {
    id: 'hotel-fitout',
    label: 'Hospitality Fit-Out',
    title: 'Hotel chain full fit-out at 45% under Irish wholesale cost',
    summary: 'A hotel group fitting out three new properties in Ireland needed furniture, lighting, ceramics, and FF&E (furniture, fixtures and equipment). All categories were priced against Irish and UK supply. Factory-direct from Foshan (furniture + ceramics) and Zhongshan (lighting) came in 45% under the best Irish wholesale quote.',
    results: [
      '45% below Irish wholesale across all FF&E categories',
      'CE compliance verified across all products before shipment',
      'Full container delivery coordinated to site — no Irish importer middleman',
      'Project delivered on schedule across all three properties',
    ],
    note: 'Total project value: €800,000+. Client identity withheld.',
  },
  {
    id: 'electronics-retail',
    label: 'Electronics Retail',
    title: 'Electronics retailer cut landed cost by 52%',
    summary: 'A specialist electronics retailer was buying through an Irish importer who sourced via Alibaba trading companies. We identified the actual manufacturer in Shenzhen, negotiated directly, and reduced the supply chain from 4 layers to 1.',
    results: [
      '52% reduction in landed cost vs previous supply chain',
      'Lead times reduced by 8 days on average',
      'Fake CE documentation identified and replaced with legitimate certification',
      'Order volume increased 3x as margins improved',
    ],
    note: 'Category: consumer electronics accessories. Client identity withheld.',
  },
  {
    id: 'construction',
    label: 'Construction & Materials',
    title: 'Construction contractor sourced structural materials, CE compliant, at 38% below quoted UK price',
    summary: 'A fit-out contractor needed aluminium profiles, sanitaryware, and commercial lighting for a large commercial fit-out. All products required CE marking and product compliance documentation. We sourced direct from Henan (aluminium), Foshan (sanitaryware), and Zhongshan (commercial lighting), with full compliance documentation provided before delivery.',
    results: [
      '38% below best UK supply quote, landed in Ireland',
      'All products supplied with valid CE and EU Declaration of Conformity',
      'NSAI-format compliance documentation provided for each product category',
      'Delivered on a phased schedule matching site programme',
    ],
    note: 'Project size: €220,000. Client identity withheld.',
  },
];
---

<BaseLayout title={title} description={description} canonical="/case-studies">

  <section class="page-hero section--lg">
    <div class="container--narrow">
      <span class="section-eyebrow">Case Studies</span>
      <h1>What factory-direct actually looks like in practice.</h1>
      <p class="lead">Real results from real sourcing projects. Client names are withheld by agreement, but the numbers and outcomes are real. This is what changes when you remove the middlemen.</p>
    </div>
  </section>

  <section class="cases-section section section--alt">
    <div class="container">
      <div class="cases-list">
        {caseStudies.map(cs => (
          <div class="case-card" id={cs.id}>
            <div class="case-header">
              <span class="case-label">{cs.label}</span>
              <h2>{cs.title}</h2>
            </div>
            <div class="case-body">
              <div class="case-summary">
                <p>{cs.summary}</p>
                <p class="case-note">{cs.note}</p>
              </div>
              <div class="case-results">
                <h3>Results</h3>
                <ul>
                  {cs.results.map(r => <li>{r}</li>)}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-strip section--emerald">
    <div class="container--narrow" style="text-align:center">
      <span class="section-eyebrow section-eyebrow--light">Your turn</span>
      <h2>Want results like these?</h2>
      <p>Send me a brief. I'll tell you what your product category actually costs at factory gate — and what you should be paying.</p>
      <a href="/contact" class="btn btn--white">Get a Sourcing Quote →</a>
    </div>
  </section>

</BaseLayout>

<style>
  .page-hero { border-bottom: 1px solid rgba(15,33,49,.08); }
  .page-hero h1 { font-size: clamp(2.25rem, 5vw, 4rem); }
  .lead { font-size: 1.25rem; color: #5a5a5a; line-height: 1.7; margin: 1rem 0 0; max-width: 56ch; }

  .cases-list { display: flex; flex-direction: column; gap: 2.5rem; }
  .case-card { background: var(--color-white); border: 1px solid rgba(15,33,49,.08); border-radius: var(--radius-lg); overflow: hidden; }
  .case-header { padding: 2rem 2rem 1.25rem; border-bottom: 1px solid rgba(15,33,49,.07); }
  .case-label { display: inline-block; font-size: .75rem; font-weight: 700; color: var(--color-teal); text-transform: uppercase; letter-spacing: .07em; margin-bottom: .625rem; }
  .case-header h2 { font-size: 1.375rem; margin: 0; }
  .case-body { display: grid; grid-template-columns: 1.4fr 1fr; gap: 0; }
  .case-summary { padding: 1.75rem 2rem; border-right: 1px solid rgba(15,33,49,.07); }
  .case-summary p { color: var(--color-slate); font-size: .9375rem; line-height: 1.7; margin-bottom: .875rem; max-width: none; }
  .case-note { font-size: .8125rem; color: var(--color-grey); font-style: italic; margin-bottom: 0 !important; }
  .case-results { padding: 1.75rem 2rem; background: rgba(26,83,62,.03); }
  .case-results h3 { font-size: .875rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: var(--color-grey); margin-bottom: 1rem; }
  .case-results ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .75rem; }
  .case-results li { font-size: .9375rem; color: var(--color-navy); font-weight: 500; padding-left: 1.5rem; position: relative; line-height: 1.45; }
  .case-results li::before { content: '✓'; position: absolute; left: 0; color: var(--color-emerald); font-weight: 700; }

  .cta-strip { padding: 5rem 0; }
  .cta-strip h2 { font-size: clamp(1.75rem, 4vw, 3rem); margin-bottom: 1rem; }
  .cta-strip p { font-size: 1.125rem; margin: 0 auto 2rem; max-width: 50ch; }

  @media (max-width: 900px) {
    .case-body { grid-template-columns: 1fr; }
    .case-summary { border-right: none; border-bottom: 1px solid rgba(15,33,49,.07); }
  }
  @media (max-width: 540px) {
    .case-header, .case-summary, .case-results { padding: 1.25rem; }
  }
</style>
