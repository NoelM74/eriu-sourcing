---
// Footer.astro — Ériu Sourcing
// Emerald brand footer — warm off-white top band + deep emerald lower section

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">

  <!-- Top band — warm off-white, contact strip -->
  <div class="footer-top">
    <div class="container">
      <div class="footer-top-inner">
        <div class="footer-contact-line">
          <span>Ready to start sourcing direct?</span>
          <a href="https://wa.me/353871187806" class="wa-btn" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp Noel
          </a>
          <a href="/contact" class="quote-btn">Get a Quote →</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Main footer — deep emerald -->
  <div class="footer-main">
    <div class="container">
      <div class="footer-grid">

        <!-- Brand column -->
        <div class="footer-brand">
          <!-- Logo — light version for emerald background -->
          <a href="/" class="footer-logo" aria-label="Ériu Sourcing — Home">
            <span class="footer-logo-eriu">ÉRIU</span><span class="footer-logo-sourcing">Sourcing</span>
          </a>
          <p>Factory-direct from China to Ireland. Based in Zhengzhou and Shenzhen. 18 years of factory-level relationships.</p>
          <p class="footer-location">Zhengzhou, Henan &amp; Shenzhen, Guangdong</p>
          <p class="footer-address">Springfield, Clonlara, Co. Clare, Ireland</p>
        </div>

        <!-- Services -->
        <div class="footer-col">
          <h4>Services</h4>
          <ul>
            <li><a href="/product-categories/">What We Source</a></li>
            <li><a href="/source/">Sourcing Guides</a></li>
            <li><a href="/how-it-works/">How It Works</a></li>
            <li><a href="/why-direct/">Why Buy Direct?</a></li>
            <li><a href="/contact/">Get a Quote</a></li>
          </ul>
        </div>

        <!-- Categories -->
        <div class="footer-col">
          <h4>Categories</h4>
          <ul>
            <li><a href="/product-categories/#fashion">Fashion &amp; Apparel</a></li>
            <li><a href="/product-categories/#electronics">Electronics</a></li>
            <li><a href="/product-categories/#furniture">Furniture</a></li>
            <li><a href="/product-categories/#construction">Construction Materials</a></li>
            <li><a href="/product-categories/#hospitality">Hospitality Fit-Out</a></li>
            <li><a href="/product-categories/#modular-buildings">Modular Buildings</a></li>
          </ul>
        </div>

        <!-- About -->
        <div class="footer-col">
          <h4>About</h4>
          <ul>
            <li><a href="/china-network/">Our China Network</a></li>
            <li><a href="/case-studies/">Case Studies</a></li>
            <li><a href="/about/">About Noel Murphy</a></li>
            <li><a href="/contact/">Contact</a></li>
          </ul>
        </div>

      </div>

      <div class="footer-bottom">
        <p>&copy; {currentYear} Ériu Sourcing. All rights reserved. · Springfield, Clonlara, Co. Clare, Ireland</p>
        <p class="footer-legal">
          <a href="/privacy/">Privacy Policy</a>
          <span aria-hidden="true">·</span>
          <a href="/terms/">Terms of Service</a>
        </p>
      </div>
    </div>
  </div>

</footer>

<style>
  /* Top contact band */
  .footer-top {
    background-color: #EFEEE9;
    border-top: 1px solid rgba(15, 33, 49, 0.1);
    padding: 1.25rem 0;
  }

  .footer-contact-line {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .footer-contact-line > span {
    font-size: 1rem;
    font-weight: 600;
    color: #0F2131;
    flex: 1;
    min-width: 200px;
  }

  .wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1a7a35;
    text-decoration: none;
    padding: 0.625rem 1.25rem;
    border: 2px solid #1a7a35;
    border-radius: 8px;
    min-height: 44px;
    transition: background-color 0.12s ease, color 0.12s ease;
  }

  .wa-btn:hover {
    background-color: #1a7a35;
    color: #ffffff;
  }

  .quote-btn {
    display: inline-flex;
    align-items: center;
    font-size: 0.9375rem;
    font-weight: 700;
    color: #ffffff;
    background-color: #1A533E;
    text-decoration: none;
    padding: 0.625rem 1.5rem;
    border: 2px solid #1A533E;
    border-radius: 8px;
    min-height: 44px;
    transition: background-color 0.12s ease;
  }

  .quote-btn:hover {
    background-color: #133d2e;
    border-color: #133d2e;
    color: #ffffff;
  }

  /* Main emerald footer */
  .footer-main {
    background-color: #1A533E;
    padding: 3.5rem 0 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 2.5rem;
  }

  .footer-logo {
    text-decoration: none;
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    margin-bottom: 1.125rem;
    line-height: 1;
  }

  .footer-logo-eriu {
    font-family: 'Boska', Georgia, 'Times New Roman', serif;
    font-size: 1.625rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .footer-logo-sourcing {
    font-family: 'Satoshi', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 1.25rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.02em;
    line-height: 1;
  }

  .footer-brand p {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 0.75rem;
    max-width: 30ch;
  }

  .footer-location {
    font-size: 0.8125rem !important;
    color: rgba(255, 255, 255, 0.45) !important;
  }

  .footer-address {
    font-size: 0.8125rem !important;
    color: rgba(255, 255, 255, 0.4) !important;
    margin-top: 0 !important;
  }

  .footer-legal {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.38);
    margin: 0;
  }

  .footer-legal a {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.12s;
  }

  .footer-legal a:hover { color: rgba(255, 255, 255, 0.85); }

  .footer-col h4 {
    font-family: var(--font-body, sans-serif);
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.45);
    text-transform: uppercase;
    letter-spacing: 0.09em;
    margin-bottom: 1rem;
  }

  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-col li {
    margin-bottom: 0.5rem;
  }

  .footer-col a {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    min-height: 32px;
    display: inline-flex;
    align-items: center;
    transition: color 0.12s ease;
  }

  .footer-col a:hover {
    color: #ffffff;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-bottom p {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.38);
    margin: 0;
    max-width: none;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer-contact-line {
      gap: 1rem;
    }

    .footer-contact-line > span {
      width: 100%;
    }
  }

  @media (max-width: 440px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
