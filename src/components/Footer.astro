---
// Footer.astro — Ériu Sourcing

const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">

      <!-- Brand column -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">Ériu Sourcing</a>
        <p>Factory-direct sourcing from China to Ireland. Based in Zhengzhou and Shenzhen. 18 years in-country experience.</p>
        <a href="https://wa.me/353871187806" class="whatsapp-link" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp Noel">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp: +353 87 118 7806
        </a>
      </div>

      <!-- Services column -->
      <div class="footer-col">
        <h4>Services</h4>
        <ul>
          <li><a href="/product-categories">What We Source</a></li>
          <li><a href="/how-it-works">How It Works</a></li>
          <li><a href="/why-direct">Why Buy Direct?</a></li>
          <li><a href="/contact">Get a Quote</a></li>
        </ul>
      </div>

      <!-- Categories column -->
      <div class="footer-col">
        <h4>Categories</h4>
        <ul>
          <li><a href="/product-categories#fashion">Fashion & Apparel</a></li>
          <li><a href="/product-categories#electronics">Electronics</a></li>
          <li><a href="/product-categories#furniture">Furniture</a></li>
          <li><a href="/product-categories#construction">Construction Materials</a></li>
          <li><a href="/product-categories#hospitality">Hospitality Fit-Out</a></li>
          <li><a href="/product-categories#modular-buildings">Modular Buildings</a></li>
        </ul>
      </div>

      <!-- About column -->
      <div class="footer-col">
        <h4>About</h4>
        <ul>
          <li><a href="/china-network">Our China Network</a></li>
          <li><a href="/case-studies">Case Studies</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
        <p class="footer-location">📍 Zhengzhou, Henan &amp; Shenzhen, Guangdong</p>
      </div>

    </div><!-- /.footer-grid -->

    <div class="footer-bottom">
      <p>&copy; {currentYear} Ériu Sourcing. All rights reserved.</p>
      <p class="footer-note">Factory-direct sourcing for Irish and UK businesses. Registered in Ireland.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-navy);
    color: rgba(255, 255, 255, 0.75);
    padding: 4rem 0 2rem;
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  /* Brand */
  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: #ffffff;
    text-decoration: none;
    display: block;
    margin-bottom: 0.875rem;
  }

  .footer-brand p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 1.25rem;
    max-width: 32ch;
  }

  .whatsapp-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #4ECB71;
    text-decoration: none;
    min-height: 44px;
  }

  .whatsapp-link:hover {
    color: #72DA8A;
  }

  /* Columns */
  .footer-col h4 {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.45);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
  }

  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-col li {
    margin-bottom: 0.5rem;
  }

  .footer-col a {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    min-height: 28px;
    display: inline-flex;
    align-items: center;
    transition: color 0.12s ease;
  }

  .footer-col a:hover {
    color: #ffffff;
  }

  .footer-location {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.45);
    margin-top: 1.25rem;
    line-height: 1.5;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-bottom p {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
  }

  .footer-note {
    text-align: right;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 540px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer-note {
      text-align: left;
    }
  }
</style>
