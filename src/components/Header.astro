---
// Header.astro — Ériu Sourcing
// Mobile-first sticky nav. Logo is inline SVG lockup (light-bg variant).

const navLinks = [
  { href: '/how-it-works',      label: 'How It Works' },
  { href: '/product-categories',label: 'What We Source' },
  { href: '/why-direct',        label: 'Why Direct?' },
  { href: '/china-network',     label: 'China Network' },
  { href: '/case-studies',      label: 'Case Studies' },
];

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-inner container">

    <!-- Logo — HTML text using loaded Fontshare fonts -->
    <a href="/" class="logo" aria-label="Ériu Sourcing — Home">
      <span class="logo-eriu">ÉRIU</span><span class="logo-sourcing">Sourcing</span>
    </a>

    <!-- Desktop nav -->
    <nav class="nav-desktop" aria-label="Main navigation">
      <ul role="list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={pathname === link.href || pathname.startsWith(link.href + '/') ? 'active' : ''}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- CTA -->
    <a href="/contact" class="btn btn--primary nav-cta">Get a Quote</a>

    <!-- Hamburger -->
    <button
      class="hamburger"
      id="nav-toggle"
      aria-expanded="false"
      aria-controls="mobile-nav"
      aria-label="Open menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

  </div>

  <!-- Mobile nav drawer -->
  <nav
    class="nav-mobile"
    id="mobile-nav"
    aria-label="Mobile navigation"
    aria-hidden="true"
  >
    <ul role="list">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class={pathname === link.href || pathname.startsWith(link.href + '/') ? 'active' : ''}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="mobile-cta-item">
        <a href="/contact" class="btn btn--primary mobile-cta-btn">Get a Quote</a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const mobileNav = document.getElementById('mobile-nav');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
    mobileNav?.setAttribute('aria-hidden', String(isOpen));
    mobileNav?.classList.toggle('is-open');
    toggle.classList.toggle('is-open');
    document.body.style.overflow = isOpen ? '' : 'hidden';
  });

  mobileNav?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Open menu');
      mobileNav.setAttribute('aria-hidden', 'true');
      mobileNav.classList.remove('is-open');
      toggle?.classList.remove('is-open');
      document.body.style.overflow = '';
    });
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: #F7F6F2;
    border-bottom: 1px solid rgba(15, 33, 49, 0.09);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 72px;
  }

  /* Logo */
  .logo {
    text-decoration: none;
    flex-shrink: 0;
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    line-height: 1;
  }

  .logo-eriu {
    font-family: 'Boska', Georgia, 'Times New Roman', serif;
    font-size: 1.625rem;
    font-weight: 700;
    color: #1A533E;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .logo-sourcing {
    font-family: 'Satoshi', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 1.25rem;
    font-weight: 400;
    color: #0F2131;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  /* Desktop nav */
  .nav-desktop {
    flex: 1;
  }

  .nav-desktop ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0;
  }

  .nav-desktop a {
    font-size: 0.9375rem;
    font-weight: 500;
    color: #3a3a3a;
    text-decoration: none;
    padding: 0.5rem 0.875rem;
    border-radius: 6px;
    min-height: 44px;
    display: flex;
    align-items: center;
    transition: color 0.12s ease, background-color 0.12s ease;
  }

  .nav-desktop a:hover {
    color: #1A533E;
    background-color: rgba(26, 83, 62, 0.07);
  }

  .nav-desktop a.active {
    color: #1A533E;
    font-weight: 600;
  }

  /* Header CTA */
  .nav-cta {
    flex-shrink: 0;
    font-size: 0.9375rem;
    padding: 0.625rem 1.375rem;
    min-height: 44px;
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    margin-left: auto;
    flex-shrink: 0;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background-color: #0F2131;
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
    transform-origin: center;
  }

  .hamburger.is-open span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
  .hamburger.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.is-open span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

  /* Mobile drawer */
  .nav-mobile {
    display: none;
    background-color: #F7F6F2;
    border-top: 1px solid rgba(15, 33, 49, 0.08);
    padding: 1.25rem 1.5rem 2rem;
  }

  .nav-mobile.is-open {
    display: block;
  }

  .nav-mobile ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-mobile a {
    display: flex;
    align-items: center;
    min-height: 52px;
    font-size: 1.125rem;
    font-weight: 500;
    color: #0F2131;
    text-decoration: none;
    padding: 0.25rem 0;
    border-bottom: 1px solid rgba(15, 33, 49, 0.07);
    transition: color 0.12s ease;
  }

  .nav-mobile a:hover,
  .nav-mobile a.active {
    color: #1A533E;
  }

  .mobile-cta-item {
    margin-top: 1.5rem;
  }

  .mobile-cta-btn {
    border: none !important;
    width: 100%;
    justify-content: center;
  }

  /* Responsive */
  @media (max-width: 960px) {
    .nav-desktop,
    .nav-cta {
      display: none;
    }

    .hamburger {
      display: flex;
    }
  }
</style>
